// Prisma schema para eventos, chats suscritos y OTPs

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum EventType {
    MEETING
    REMINDER
    ALERT
    // Agrega más tipos si los necesitas
}

model Event {
    id          Int       @id @default(autoincrement())
    title       String
    description String
    type        EventType // Usamos enum en lugar de string libre
    ownerId     String
    ownerDomain String
    createdAt   DateTime  @default(now())

    chats ChatOnEvent[]
}

model Chat {
    id        BigInt  @id // Telegram chat id
    type      String
    title     String?
    username  String?
    firstName String?
    lastName  String?
    phone     String  @unique // Ahora es requerido para relaciones sólidas

    events    ChatOnEvent[]
    eventOtps EventOtp[]
}

model ChatOnEvent {
    id Int @id @default(autoincrement())

    event   Event @relation(fields: [eventId], references: [id])
    eventId Int

    chat   Chat   @relation(fields: [chatId], references: [id])
    chatId BigInt

    @@unique([chatId, eventId]) // Para evitar duplicados
}

model EventOtp {
    id Int @id @default(autoincrement())

    phoneVinculate String   @unique
    otp            String
    createdAt      DateTime @default(now())

    chat Chat @relation(fields: [phoneVinculate], references: [phone])
}

//---- Agent Schema ---------------------------------------------
// ==== ENUMS ====

enum AgentType {
    generic
    transactional
    client_owned
}

enum SessionStatus {
    connected
    disconnected
    banned
    error
}

// ==== MODELS ====

model Agent {
    id      String    @id @default(uuid())
    phone   String    @unique
    alias   String
    type    AgentType
    ownerId String? // Puede ser null si es generic o transactional

    categories        String[] // Array de strings
    blockedCategories String[] // Array de strings

    profile      Profile?
    session      Session?
    limits       Limits?
    availability Availability?
    antiBan      AntiBan?
    stats        Stats?

    contactsInteracted ContactInteraction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Profile {
    id                  String  @id @default(uuid())
    displayName         String
    profilePictureUrl   String
    businessDescription String
    verified            Boolean
    agent               Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId             String  @unique
}

model Session {
    id                 String        @id @default(uuid())
    status             SessionStatus
    lastConnectedAt    DateTime
    baileysSessionPath String
    errorMessage       String?
    agent              Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId            String        @unique
}

model Limits {
    id                            String @id @default(uuid())
    maxMessagesPerDay             Int
    maxMessagesPerHour            Int
    maxConcurrentMessages         Int
    maxRepeatedMessagesPerContact Int
    agent                         Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId                       String @unique
}

model Availability {
    id          String @id @default(uuid())
    activeHours Json // [{ start: "HH:mm", end: "HH:mm" }]
    timeZone    String
    agent       Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId     String @unique
}

model AntiBan {
    id                   String    @id @default(uuid())
    riskScore            Float
    cooldownDelayMs      Int
    lastRiskAssessmentAt DateTime
    lastBanCheckAt       DateTime?
    agent                Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId              String    @unique
}

model Stats {
    id                String   @id @default(uuid())
    messagesSentToday Int
    messagesSentTotal Int
    successRate       Float
    lastMessageAt     DateTime
    agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId           String   @unique
}

model ContactInteraction {
    id                String    @id @default(uuid())
    phone             String
    lastInteractionAt DateTime
    messagesSentCount Int
    lastReplyAt       DateTime?
    agent             Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
    agentId           String
}

model NotificationLog {
    id        String   @id @default(uuid())
    trxId     String?
    phone     String
    agent     String
    payload   Json
    status    String
    error     String?
    createdAt DateTime @default(now())
}
